{
  "expo": {
    "name": "tir",
    "slug": "tir",
    "scheme": "tirapp",
    "ios": {
      "bundleIdentifier": "com.tirapp",
      "supportsTablet": false,
      "googleServicesFile": "./ios/GoogleService-Info.plist"
    },
    "android": {
      "package": "com.tirapp",
      "versionCode": 1,
      "googleServicesFile": "./android/app/google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/icon-1024.png",
        "backgroundColor": "#0B0B12"
      }
    },
    "plugins": [
      "expo-dev-client",
      "@react-native-firebase/app",
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c9f55a09-6e7d-4dde-9260-7b14515d39ae"
      }
    },
    "owner": "4m4n5"
  }
}
