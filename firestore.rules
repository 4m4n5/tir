rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /_debug/{docId} {
      allow read, write: if signedIn();
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow create, update, delete: if false;

      match /rounds/{roundId} {
        allow read: if signedIn();
        allow write: if false;
      }

      match /players/{playerId} {
        allow read: if signedIn();
        allow write: if false;
      }

      match /events/{eventId} {
        allow read: if signedIn();
        allow write: if false;
      }
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      // Client may write only identity + onboarding-complete markers.
      // Everything else (rating, streaks, counters) is server-managed
      // by Cloud Functions via the admin SDK, which bypasses rules.
      allow update: if signedIn() && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['displayName', 'avatarEmoji', 'updatedAt', 'tutorialCompletedAt']);
      allow create: if signedIn() && request.auth.uid == userId
        && request.resource.data.keys()
            .hasOnly(['displayName', 'avatarEmoji', 'updatedAt', 'tutorialCompletedAt']);
    }

    match /publicProfiles/{userId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /meta/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /cache/{document=**} {
      allow read, write: if false;
    }

    match /analytics/{document=**} {
      allow read, write: if false;
    }

    match /rewardLocks/{docId} {
      allow read, write: if false;
    }

    match /finalizeLocks/{docId} {
      allow read, write: if false;
    }
  }
}
